# Change if running multile server/admin containers

SERVER_CONTAINER_NAME="rust-server"
ADMIN_CONTAINER_NAME="rust-admin"

SERVER_PORT=28015
QUERY_PORT=28017
APP_PORT=28082

# PUBLIC-FACING DATABASE! USE SECURE CREDENTIALS!

INFLUXDB_USER_PASSWORD="CHANGE_ME_TO_SECURE_PASSWORD"

# https://console.cloud.google.com/auth/clients/create

GOOGLE_OAUTH_CLIENT_ID="CHANGE_ME.apps.googleusercontent.com"
GOOGLE_OAUTH_CLIENT_SECRET="CHANGE_ME"

# Can be found after unsuccessful login (caddy rcon.)

WHITE_LISTED_GOOGLE_OPEN_IDS="CHANGE_ME" # comma separated

ORIGINAL_PAGE="https://CHANGE.ME"